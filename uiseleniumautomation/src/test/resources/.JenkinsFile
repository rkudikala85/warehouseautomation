pipeline {
  agent any
  stages {
    stage('Build') {
      steps {
        echo 'Building...'
        sh 'mvn clean compile'
      }
    }
    stage('Test') {
      steps {
        echo 'Running Tests...'
        sh 'mvn test'
      }
    }
    stage('Report') {
      steps {
        echo 'Publishing Reports...'
      }
    }
  }
}
